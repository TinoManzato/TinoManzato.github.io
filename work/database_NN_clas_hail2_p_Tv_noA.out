> intensity <- vector(l=totcasi)
> intensityo <- vector()
> 
> for(i in 1:totcasi)
+ {
+ 	dati[i,1:(nvar-4)] <- datitmp[i,]
+ 
+ 	# Wind speed of LowLevelWind:
+ 	if(!is.na(dati[i,which(campo=="LLWu")]) && !is.na(dati[i,which(campo=="LLWv")]))
+ 		dati[i,nvar-2] <- sqrt((dati[i,which(campo=="LLWu")])^2 + (dati[i,which(campo=="LLWv")])^2)
+ 	else
+ 		dati[i,nvar-2] <- NaN
+ 
+ 	# Wind speed of MiddleLevelWind:
+ 	if(!is.na(dati[i,which(campo=="MLWu")]) && !is.na(dati[i,which(campo=="MLWv")]))
+ 		dati[i,nvar-1] <- sqrt((dati[i,which(campo=="MLWu")])^2 + (dati[i,which(campo=="MLWv")])^2)
+ 	else
+ 		dati[i,nvar-1] <- NaN
+ 	
+ 	# |VFlux| :
+ 	# Aggiungo il modulo del flusso lungo la componente V
+ 	if(!is.na(dati[i,which(campo=="VFlux")]))
+ 		dati[i,nvar-3] <- abs(dati[i,which(campo=="VFlux")])
+ 	else
+ 		dati[i,nvar-3] <- NaN
+ 
+ 
+ 
+ 	# Change the activity variables (mean and maximum) into ln(1+X):
+ 	# activity :
+ 	for(var in 6:17)
+ 	{
+ 		if(campo[var] == "NegLightInt" || campo[var] == "NegLightIntMax")
+ 			dati[i,var] <- ifelse(is.na(dati[i,var]), NaN, -log(1-dati[i,var]))
+ 		else
+ 			dati[i,var] <- ifelse(is.na(dati[i,var]), NaN, log(1+dati[i,var]))
+ 	}
+ 
+ 	# filter out some errors in VVstd:
+ 	if (!is.na(dati[i,which(campo=="VVstd")]) && abs(dati[i,which(campo=="VVstd")]) > 7)
+ 	{
+ 		cat("Out of range in VVstd")
+ 		cat(dati[i,which(campo=="VVstd")],"\n")
+ 		dati[i,which(campo=="VVstd")] <- NaN
+ 	}
+ 	# filter out some errors in BRI:
+ 	if (!is.na(dati[i,which(campo=="BRI")]) && abs(dati[i,which(campo=="BRI")]) > 1500)
+ 	{
+ 		cat("Out of range in BRI")
+ 		cat(dati[i,which(campo=="BRI")],"\n")
+ 		dati[i,which(campo=="BRI")] <- NaN
+ 	}
+ 	# filter out some errors in EHI:
+ 	if (!is.na(dati[i,which(campo=="EHI")]) && abs(dati[i,which(campo=="EHI")]) > 4)
+ 	{
+ 		cat("Out of range in EHI")
+ 		cat(dati[i,which(campo=="EHI")],"\n")
+ 		dati[i,which(campo=="EHI")] <- NaN
+ 	}
+ 	# filter out some errors in Hel:
+ 	if (!is.na(dati[i,which(campo=="Hel")]) && abs(dati[i,which(campo=="Hel")]) > 500)
+ 	{
+ 		cat("Out of range in Hel")
+ 		cat(dati[i,which(campo=="Hel")],dati[i,],"\n")
+ 		dati[i,which(campo=="Hel")] <- NaN
+ 	}
+ 	# filter out some errors in Rel_Hel:
+ 	if (!is.na(dati[i,which(campo=="Rel_Hel")]) && abs(dati[i,which(campo=="Rel_Hel")]) > 1500)
+ 	{
+ 		cat("Out of range in Rel_Hel")
+ 		cat(dati[i,which(campo=="Rel_Hel")],dati[i,],"\n")
+ 		dati[i,which(campo=="Rel_Hel")] <- NaN
+ 	}
+ }
