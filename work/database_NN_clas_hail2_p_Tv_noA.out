+ 	 	fun <- function(p) sum((newcas*(pro - (p[1] + p[2] * atan(p[3] + p[4]*bx))))^2)
+ 	 	#fun <- function(p) sum(newcas*(pro - (p[1] + p[2] * atan(p[3] + p[4]*bx)))^2)
+ 	 	out <- nlm(fun, p=c(1,1,1,1), hessian=T)
+ 	 	fp <-  function(x) out$estimate[1]+out$estimate[2]*atan(out$estimate[3]+out$estimate[4]*x)
+ 		#cat(out$estimate[1],"+",out$estimate[2],"*atan(",out$estimate[3],"+",out$estimate[4],"*x")
+ 	 }
