> #hail <- 1   # minimum number of hailpads to have an "active hail" 6h case 
> # dal 16/04/07 ne tengo almeno due!
> hail <- 2   # minimum number of hailpads to have an "active hail" 6h case 
> 
> cat("Computing activity variable (at least 2 hailpad/6h)...\n")
Computing activity variable (at least 2 hailpad/6h)...
> activity <- vector(length = totcasi)
> activitypro <- vector(length = totcasi)
> activitypro2 <- vector(length = totcasi)
> onlyact1 <- vector()
> onlyact2 <- vector()
> onlyact3 <- vector()
> 
> #acttr <- 0.5
> acttr <- 0.1	# se uso activity
> 
> s <- 0
> j <- 1
> for(i in 1:totcasi)
+ {	
+ 	# Forse sarebbe meglio dividere per 3 per essere sempre < 1!
+ 	#if (dati[i,7] > 0.6)	# almost 1 lightning
+ 	#if (dati[i,7] > 1.3)	# almost 3 lightning
+         #if (dati[i,which(campo=="Rain6HourMax")] >= 1.8)    # almost 5.05 mm/6h
+         if (!is.na(dati[i,which(campo=="HailPads")]) && round(4*dati[i,which(campo=="HailPads")], 0) >= hail)  # almost 2 hailpads in 6h. HailPads NON puo' mai essere missing
+ 	{
+ 		# activity[i] <- (1/8*dati[i,7] + 1/6*dati[i,10] + 1/3*dati[i,11])/2.9
+ 		# Attivita' in 2 classi (0,1) per avere le posterior probability
+ 		activity[i] <- 1
+ 		TotHailPads <- round(4*dati[i,which(campo=="HailPads")], 0)
+ 		onlyact1[j] <- TotHailPads # salvo il num. intero di pannelli totali
+ 		j <- j + 1
+ 	}
+ 	else 
+ 		activity[i] <- 0
+ 
+ 	## Discretizzo l'attivita' per migliorare la presenza:
+ 	#if (activity[i] > acttr)
+ 	#{
+ 	#	if (activity[i] < 0.4)
+ 	#		activity[i] <- 0.4
+ 	#	else
+ 	#		activity[i] <- 1
+ 	#}
+ 	#else 
+ 	#	activity[i] <- 0
+ 
+ 	# ACTP: save the activity of six hour before - ATTivita' Precedente
+ 	# Mi serve JJJ non trasformato!
+ 	# 6h = 0.25 in Julian day
+ 	if (i > 1)
+ 	{
+ 		if ((dati[i,which(campo=="JJJ")] - dati[(i-1),which(campo=="JJJ")]) == 0.25)
+ 			dati[i,nvar] <- activity[i-1]
+ 		else
+ 			# Achtung: 20070816 metto 0 se manca l'attivita' precedente per evitare il 42% di missing nel 2005 e 2006.
+ 			#dati[i,nvar] <- NaN
+ 			dati[i,nvar] <- 0
+ 	}
+ 	else
+ 		dati[i,nvar] <- NaN
+ 	
+ }
