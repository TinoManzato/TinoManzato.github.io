+ 	 # fine definizione funzioni di probabilita'.
+ 	 #************************************************************
+ 
+ 	 # RICORDADATI di filtrare cosi':
+ 	 ##fp <- function(x) {if (f(x)>0) {if (f(x)<1 f(x) else 1} else 0}
+ 
+ 	 jn <- 1
+ 	 jy <- 1
+ 	 # Transform real data into its probability:
+ 	 for (j in 1:totcasi)
+ 	 {
+ 	  if (is.na(dati[j,i]))
+ 		prodati[j,i] <- NaN
+ 	  else
+ 	  {	# if HH set equal to the class probability, not to the interpolated function fp:
+ 		if (i == 4)
+ 		{
+ 			hour <- (as.integer((dati[j,i] + 3)/6) + 1)
+ 			if (hour == 5)		# HH = 24
+ 				hour <- 1	
+ 			prodati[j,i] <- pro[hour]
+ 		}
+ 		else
+ 		{
+ 		 prob <- fp(dati[j,i])
+ 		 if (prob > 1)
+ 			prob <- 1
+ 		 if (prob < 0)
+ 			prob <- 0
+ 	  	 prodati[j,i] <- prob
+ 		}
+ 	  }
+ 	  if (activity[j] > acttr)
+ 	  {
+ 		proyes[jy] <- prodati[j,i]
+ 		datyes[jy] <- dati[j,i]
+ 		jy <- jy + 1
+ 	  }
+ 	  else
+ 	  {
+ 		prono[jn] <- prodati[j,i]
+ 		datno[jy] <- dati[j,i]
+ 		jn <- jn + 1
+ 	  }
+ 	 }
+ 
+ 	 quapt5 <- quantile(prodati[,i],probs=0.05,na.rm=TRUE)
+ 	 quapt50 <- quantile(prodati[,i],probs=0.5,na.rm=TRUE)
+ 	 quapt95 <- quantile(prodati[,i],probs=0.95,na.rm=TRUE)
+ 	 cat("\t", vtot, "Prob. tot. cases\t5% = ", quapt5, "\t50% = ", quapt50, "\t95% = ", quapt95, "\n")
+ 
+ 	 codati <- cor(activity, dati[,i], use="complete.obs")
+ 	 cat("\tCorrelation for original values:\t", (codati)^2, "\n")
+ 	 copro <- cor(activity, prodati[,i], use="complete.obs")
+ 	 cat("\tCorrelation for probability values:\t", (copro)^2, "\n")
+ 	 proymed[i] <- mean(proyes, na.rm=TRUE) 
+ 	 pronmed[i] <- mean(prono, na.rm=TRUE) 
+ 	 datymed[i] <- mean(datyes, na.rm=TRUE) 
+ 	 datnmed[i] <- mean(datno, na.rm=TRUE) 
+ 	 discr_pro <- abs((proymed[i]-pronmed[i])/(quapt95-quapt5))
+ 	 discr_dat <- abs((datymed[i]-datnmed[i])/(quat95-quat5))
+ 	 cat("\tDifference of mean value for active/non_active cases:\t",discr_dat, "\n")
+ 	 cat("\tDifference of mean probability for active/non_active cases:\t",discr_pro, "\n")
+ 
+ 	campo[i] <- paste("P(", campo[i], ")", sep="")
+ 	cat("Will use:", campo[i],"\n")
+ 
+ } 
