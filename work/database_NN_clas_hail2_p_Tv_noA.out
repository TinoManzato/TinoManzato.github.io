+ 		# cambio il 15/09/2004:
+ 	 	out <- nlm(fun, p=c(0.1,0.01,0.01), hessian=T)
+ 	 	fp <- function(x) (out$estimate[1] + out$estimate[2]*x + out$estimate[3]*x^2)
+ 	  }
+ 	  else
+ 	  {
+ 	 	fun <- function(p) sum((newcas*(pro - (p[1] + p[2] * bx)))^2)
+ 	 	out <- nlm(fun, p=c(bx[steps/4],0), hessian=T)
+ 	 	fp <- function(x) (out$estimate[1] + out$estimate[2]*x)
+ 	  }
+ 	 }
+ 
+ 	 if (campo[i] == "BOY")	# BOY
