> 
> for (i in c(4, 5, 18:nvar))
+ #for (i in c(4,  12:nvar))
+ {
+ 	cat(i, campo[i], "\n")
+ 
+ 	if (i == 4)	# HH has only 4 values
+ 	{
+ 		oldstep <- steps
+ 		steps <- 4
+ 	}
+ 	else
+ 		steps <- oldstep
+ 
+ 	pro <- vector()
+ 	proyes <- vector()
+ 	prono <- vector()
+ 	datyes <- vector()
+ 	datno <- vector()
+ 	bx <- vector()
+ 	newcas <- vector()
+ 	err <- vector()
+ 
+ 	std[i] <- sd(dati[,i], na.rm = TRUE)
+ 	media[i] <- mean(dati[,i], na.rm=TRUE)
+ 	medana[i] <- median(dati[,i], na.rm=TRUE)
+ 
+ 	# da qui e' diverso:
+ 	miv[i] <- min(dati[,i], na.rm=TRUE)
+ 	mxv[i] <- max(dati[,i], na.rm=TRUE)
+ 	mxv[i] <- mxv[i]  + (mxv[i]-miv[i]) * 0.01	# a little more to include MAX in the box before
+ 
+ 	# da qui e' di nuovo uguale:
+ 	#cat(i, campo[i])
+ 	#cat(mxv[i], miv[i], steps, "\n")
+ 	lenbox <- (mxv[i] - miv[i])/(steps - 1)
+ 	halfbox <- 1/2*lenbox
+ 
+ 	xlimi <- miv[i] - 10 * halfbox	# 5 box before
+ 	xlimx <- mxv[i] + 10 * halfbox	# 5 box after
+ 	xrang <- seq(xlimi, xlimx, length=steps+10)	# range for the prob
+ 
+ 	for (s in 0:(steps-1))
+ 	{
+ 		#clas[s+1] <- (s*(mxv[i] - miv[i])/steps +  miv[i] + halfbox)
+ 		clas[s+1] <- (s*lenbox +  miv[i])
+ 		# E' diverso da database_1_dens_cor_9502_tex_h.R :
+ 		#clas[s+1] <- (s*lenbox +  miv[i] - halfbox/2.0)
+ 		cases[s+1]  <- 0
+ 		yescas[s+1] <- 0
+ 		nocas[s+1]  <- 0
+ 	}	
+ 
+ 	if (i == 4)
+ 	{
+ 	clas <- c(0, 6, 12, 18)
+ 	#clas <- c(0.15,  0.19,  0.31, 0.35)
+ 	xrang <- c(-6, 0, 6, 12, 18, 24)
+ 	#xrang <- c(0, 0.12, 0.18, 0.24, 0.30, 0.36)
+ 	}
+ 
+ 	#cat(clas,"\n")
+ 	#cat(xrang,"\n")
+ 
+ 	yesva <- vector()
+ 	nova <- vector()
+ 	vy <- 0
+ 	vn <- 0
+ 	vtot <- 0
+ 	mis[i] <- 0
+ 
+ 
+ 	for (j in 1:totcasi)
+ 	{
+ 		#cat(i, j, dati[j,i], activity[j])
+ 		if (is.na(dati[j,i]))
+ 		{
+ 			mis[i] <- mis[i] + 1
+ 			#next
+ 		}
+ 		else
+ 		{
+ 			#if (dati == 42 && dati[j,i] > 2)
+ 			#	cat(dati[j,1], dati[j,2], dati[j,3], dati[j,4], dati[j,i], "\n")
+ 			value <- (as.integer((dati[j,i] + halfbox - miv[i])/lenbox) + 1)
+ 			cases[value] <- cases[value] + 1
+ 			vtot <- vtot + 1
+ 
+ 		 	if (activity[j] > acttr)
+ 			{
+ 				yescas[value] <- yescas[value] + 1
+ 				yesva[vy] <- dati[j,i]
+ 				if (i == 17)
+ 					LI500y[vy] <- dati[j,i]
+ 				vy <- vy + 1
+ 			}
+ 			else
+ 			{
+ 				nocas[value] <- nocas[value] + 1	
+ 				nova[vn] <- dati[j,i]
+ 				if (i == 17)
+ 					LI500n[vn] <- dati[j,i]
+ 				vn <- vn + 1
+ 			}
+ 		}
+ 	}
+ 
+ 	# for HH don't cumulate in couple:
+ 	if (i == 4)
+ 	{
+ 	 	for (s in 1:steps)
+ 	 	{
+ 			if (cases[s] > 0)
+ 			{
+ 				pro[s] <- yescas[s]/cases[s]
+ 				bx[s] <- clas[s]
+ 				newcas[s] <- cases[s]
+ 			}
+ 	 	}
+ 		ix <- 4
+ 	}
+ 	else
+ 	{	# CUMULATE clas by couple:
+ 	 noise <- 0	# filter out classes with only 1 element (noise?)
+ 
+ 	 # Add the first box if greater than "noise"
+ 	 yes <- yescas[1]
+ 	 cas <- cases[1]
+ 	 if (cas > noise)
+ 	 {
+ 		pro[1] <- yes/cas
+ 		bx[1] <- clas[1]
+ 		newcas[1] <- cas
+ 		#err[1] <- 1/steps * sqrt(1 + totcasi/(steps*cas)) 
+ 		ix <- 2
+ 	 }
+ 	 else
+ 		ix <- 1
+ 
+ 	 # Add the intermediate boxes averaged in couple:
+ 	 for (s in seq(2, steps-1, 2))	# each 2 steps
+ 	 #for (s in seq(1, steps, 2))	# each 2 steps
+ 	 #for (s in 0:(steps-1))
+ 	 {
+ 		yes <- yescas[s] + yescas[s+1]
+ 		cas <- cases[s] + cases[s+1]
+ 		xmea <- (clas[s] + clas[s+1])/2.0
+ 
+ 		if (cas > noise)	# filter out classes with only 1 element (rumor?)
+ 		{
+ 			pro[ix] <- yes/cas
+ 			bx[ix] <- xmea
+ 			newcas[ix] <- cas 
+ 			#err[ix] <- 1/steps * sqrt(1 + totcasi/(steps*cas)) 
+ 			ix <- ix + 1
+ 		}
+ 		#else
+ 			#pro[s+1] <- NaN	
+ 	 }
+ 
+ 	 # Add the last box if greater than "noise"
+ 	 yes <- yescas[steps]
+ 	 cas <- cases[steps]
+ 	 if (cas > noise)
+ 	 {
+ 		pro[ix] <- yes/cas
+ 		bx[ix] <- clas[steps]
+ 		newcas[ix] <- cas
+ 		#err[ix] <- 1/steps * sqrt(1 + totcasi/(steps*cas))
+ 		ix <- ix + 1
+ 	 }
+ 
+ 	 ix <- (ix - 1)	# number of new classes
+ 	}
+ 	# end of cumulation
+ 
+ 	# Check one variable:	
+ 	if (i == 99)
+ 	{
+ 		LI500newcas <- vector()
+ 		LI500newcas <- newcas
+ 		cat(cases, "\n")
+ 		cat(clas, "\n")
+ 		LI500yes <- yescas
+ 		LI500tot <- cases
+ 		int <- bx
+ 		LI500pro <- pro
+ 		fp <- function(x) {if (f(x)>0) f(x) else 0}
+ 	}
+ 		
+ 	# Make statistics and compute probability function:
+ 	cat(campo[i], "\tValid cases =", totcasi - mis[i])
+ 	cat("\tMin =", miv[i], "\tMax =", mxv[i], "\n")
+ 	quay5 <- quantile(yesva,probs=0.05,na.rm=TRUE)
+ 	quay50 <- quantile(yesva,probs=0.5,na.rm=TRUE)
+ 	quay95 <- quantile(yesva,probs=0.95,na.rm=TRUE)
+ 	quat5 <- quantile(dati[,i],probs=0.05,na.rm=TRUE)
+ 	quat50 <- quantile(dati[,i],probs=0.5,na.rm=TRUE)
+ 	quat95 <- quantile(dati[,i],probs=0.95,na.rm=TRUE)
+ 
+ 	cat("\tMedian =", medana[i], "\tMean =", media[i], "\tStandard Deviation =", std[i], "\n")
+ 	cat("\t", vtot, "Total cases\t5% = ", 	quat5, "\t50% = ", quat50, "\t95% = ", quat95, "\n")
+ 	cat("\t", vy, "Active cases\t5% = ", quay5, "\t50% = ", quay50, "\t95% = ", quay95, "\n")
+ 
+ 	 #************************************************************
+ 	 # Compute the probability function of each variables:
+ 	 #
+ 	 if (i > 17 && i < 62)
